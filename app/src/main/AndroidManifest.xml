<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- MQTT sobre red local (hotspot) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".AppTerapeutaApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppTerapeuta"
        tools:targetApi="31">

        <activity
            android:name=".ui.history.SessionResultDetailActivity"
            android:exported="false" />
        <activity
            android:name=".ui.history.SessionHistoryActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.ActivityCatalogActivity"
            android:exported="false" />
        <activity
            android:name=".ui.sessions.SessionLiveActivity"
            android:exported="false" />
        <activity
            android:name=".ui.sessions.SessionSetupActivity"
            android:exported="false" />
        <activity
            android:name=".ui.profiles.StudentProfileEditActivity"
            android:exported="false" />
        <activity
            android:name=".ui.profiles.StudentProfileListActivity"
            android:exported="false" />
        <activity
            android:name=".ui.robots.RobotDetailActivity"
            android:exported="false" />
        <activity
            android:name=".ui.robots.RobotListActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.PictogramActivityLauncherActivity"
            android:exported="false" />
        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".ui.therapists.TherapistManagementActivity"
            android:exported="false" />
        <activity
            android:name=".ui.dashboard.MainDashboardActivity"
            android:exported="false" />

        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
