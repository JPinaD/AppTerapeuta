<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/hud_bg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SISTEMA DE TERAPIA"
        android:textSize="26sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:textColor="@color/hud_accent_cyan"
        android:layout_marginBottom="8dp" />

    <View
        android:layout_width="200dp"
        android:layout_height="1dp"
        android:background="@color/hud_accent_cyan"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/tap_to_continue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Toque la pantalla para continuar"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:textColor="@color/hud_text_secondary" />

</LinearLayout>
