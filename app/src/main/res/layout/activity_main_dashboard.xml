<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hud_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CENTRO DE CONTROL"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textColor="@color/hud_accent_cyan"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/hud_accent_cyan"
            android:layout_marginBottom="16dp" />

        <!-- Badge sesión activa -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardActiveSession"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/hud_accent_violet"
            app:cardCornerRadius="4dp"
            app:strokeColor="@color/hud_accent_cyan"
            app:strokeWidth="1dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="▶  SESIÓN ACTIVA — Toca para volver"
                android:textColor="@color/hud_text_primary"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="14dp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Robots -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_robot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/hud_card_bg"
            app:cardCornerRadius="4dp"
            app:strokeColor="@color/hud_accent_cyan"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="[ ROBOTS ]"
                    android:textColor="@color/hud_accent_cyan"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRobots"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
                <Button
                    android:id="@+id/btnAddRobot"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="+ AÑADIR ROBOT"
                    style="@style/HUD.Button"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Alumnos -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_student"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/hud_card_bg"
            app:cardCornerRadius="4dp"
            app:strokeColor="@color/hud_accent_cyan"
            app:strokeWidth="1dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="[ ALUMNOS ]"
                android:textColor="@color/hud_accent_cyan"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:textSize="16sp"
                android:padding="16dp" />
        </com.google.android.material.card.MaterialCardView>


        <!-- Sesiones -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/hud_card_bg"
            app:cardCornerRadius="4dp"
            app:strokeColor="@color/hud_accent_cyan"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="[ SESIONES ]"
                    android:textColor="@color/hud_accent_cyan"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button
                        android:id="@+id/card_session"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="+ NUEVA SESIÓN"
                        style="@style/HUD.Button"
                        android:layout_marginEnd="4dp" />
                    <Button
                        android:id="@+id/btnSessionHistory"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="HISTORIAL"
                        style="@style/HUD.Button" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <!-- Catálogo -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_activity_catalog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/hud_card_bg"
            app:cardCornerRadius="4dp"
            app:strokeColor="@color/hud_accent_cyan"
            app:strokeWidth="1dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="[ CATÁLOGO DE ACTIVIDADES ]"
                android:textColor="@color/hud_accent_cyan"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:textSize="16sp"
                android:padding="16dp" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
