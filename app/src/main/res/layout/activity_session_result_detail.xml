<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/hud_bg"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/back_button"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="◀"
            style="@style/HUD.Button" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DETALLE DE SESIÓN"
            android:textColor="@color/hud_accent_cyan"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_gravity="center_vertical" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/hud_accent_cyan"
        android:layout_marginBottom="12dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Cabecera sesión -->
            <TextView
                android:id="@+id/tvSessionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/hud_text_primary"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <!-- Actividades y resultados -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="[ ACTIVIDADES ]"
                android:textColor="@color/hud_accent_cyan"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:id="@+id/layoutActivities"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp" />

            <!-- Incidencias -->
            <TextView
                android:id="@+id/tvIncidentsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="[ INCIDENCIAS ]"
                android:textColor="@color/hud_danger"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:visibility="gone"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:id="@+id/layoutIncidents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
