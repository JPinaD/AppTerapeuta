<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/hud_bg"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SESIÓN ACTIVA"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:textColor="@color/hud_accent_cyan"
        android:gravity="center"
        android:paddingBottom="8dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/hud_accent_cyan"
        android:layout_marginBottom="12dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRobotStatuses"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Parada de emergencia -->
    <Button
        android:id="@+id/btnEmergencyStop"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="&#9208;  PARADA DE EMERGENCIA"
        android:backgroundTint="@color/hud_accent_violet"
        android:textColor="#FFFFFF"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp" />

    <!-- Controles de pausa: visibles solo cuando hay robots PAUSED -->
    <LinearLayout
        android:id="@+id/layoutPauseControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:layout_marginBottom="4dp">

        <Button
            android:id="@+id/btnResume"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="&#9654; REANUDAR"
            style="@style/HUD.Button"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnSuspend"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="&#9209; SUSPENDER"
            style="@style/HUD.Button.Danger" />

    </LinearLayout>

    <Button
        android:id="@+id/btnBackToPanel"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="&#9664; VOLVER AL PANEL"
        style="@style/HUD.Button"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnBackToSetup"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="&#9664; CONFIGURAR"
            style="@style/HUD.Button"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnEndSession"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="&#9632; FINALIZAR"
            style="@style/HUD.Button.Danger" />

    </LinearLayout>
</LinearLayout>
